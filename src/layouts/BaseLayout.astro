---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = {
  title: string
  description: string
  ogImage: string
  canonicalUrl: string
  ogImageWidth?: number
  ogImageHeight?: number
}

const { title, description, ogImage, canonicalUrl, ogImageWidth, ogImageHeight } = Astro.props

const absoluteOgImage = new URL(ogImage, Astro.site).href

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'sapium.ai',
  url: 'https://sapium.ai',
  logo: absoluteOgImage,
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/sapium-logo.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    {ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
    <meta property="og:image:alt" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>
  <body class="bg-bgBase text-textPrimary">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 btn-primary"
    >
      Skip to main content
    </a>

    <Header />

    <slot />

    <Footer />
  </body>
</html>
