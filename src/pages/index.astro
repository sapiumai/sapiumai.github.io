---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import MissionSection from '../components/MissionSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import SolutionsSection from '../components/SolutionsSection.astro';
import TeamSection from '../components/TeamSection.astro';
import ContactCTA from '../components/ContactCTA.astro';

import mfPhoto from '../assets/team/mf.jpg';
import jmPhoto from '../assets/team/jm.jpg';
import spPhoto from '../assets/team/sp.jpg';
---

<BaseLayout
  title="sapium.ai — AI &amp; Data Consulting"
  description="sapium.ai delivers AI and data consulting, CDO-as-a-Service, and custom AI solutions for mid-tier telecom operators including MVNOs and Tier 2/3 carriers."
  ogImage="/og-default.png"
  canonicalUrl={new URL(Astro.url.pathname, Astro.site).href}
  ogImageWidth={1200}
  ogImageHeight={630}
>
  <main id="main-content">
    <Hero
      headline="ROI, not technology."
      subheadline="sapium.ai builds AI and data solutions for mid-tier telecom operators — MVNOs, Tier 2/3 carriers, and CDO-led teams that need measurable ROI, not technology for its own sake."
      primaryCta={{ label: "Start a conversation", href: "/contact" }}
      secondaryCta={{ label: "Read our work", href: "/docs" }}
    />
    <MissionSection
      heading="Why ROI first."
      body={[
        "We believe AI earns its place in a business when it changes a number that matters. Every engagement starts with identifying the metric — churn rate, cost per activation, revenue per operator — and works backward from there.",
        "Most of our clients are running operations where the data already exists and the opportunity is clear. What's missing is the engineering and analytical depth to close the gap. That's what we provide."
      ]}
    />
    <ServicesSection
      heading="What we do."
      services={[
        {
          name: "AI + Data Consulting",
          description: "Expert guidance on AI strategy, data architecture, and implementation — from identifying the right use cases to delivering production-grade systems that generate measurable returns."
        },
        {
          name: "CDO-as-a-Service",
          description: "Embedded data leadership for operators and enterprises that need Chief Data Officer judgment and accountability without the cost of a full-time executive hire."
        },
        {
          name: "Custom AI Solutions",
          description: "End-to-end development of machine learning models, feature pipelines, and intelligent automation — built for your specific data environment, not adapted from a generic template."
        },
        {
          name: "Telco Data Expertise",
          description: "Specialised AI and data delivery for MVNOs, MVNEs, and Tier 2/3 operators — from CDR analytics and churn prediction to network intelligence and revenue assurance."
        }
      ]}
    />
    <SolutionsSection
      heading="What we've built."
      subheading="Proof of execution across two industries."
      solutions={[
        {
          industry: "TELCO · MVNO/MVNE",
          title: "Telco Feature Generation Platform",
          description: "Designed and deployed an ML feature pipeline for a Tier 2 MVNO/MVNE operator, generating subscriber behavioural signals from raw CDRs. The platform replaced a third-party analytics dependency and now feeds production churn prediction and revenue assurance models from the operator's own data estate."
        },
        {
          industry: "MINING · COMPUTER VISION",
          title: "Ore Classification System",
          description: "Built a real-time ore grade classification system using computer vision for an open-pit mining operation. Convolutional models analyse belt conveyor imagery to automate grade assessment, replacing manual sampling and enabling faster feed-blend decisions with higher confidence."
        }
      ]}
    />
    <TeamSection
      heading="The team."
      members={[
        {
          name: "Mauricio Falck",
          role: "CTO",
          bio: "Three decades operating telecom IT systems — BSS/OSS stacks, large-scale system architecture, and AI delivery across consulting and in-house roles. At sapium.ai, Mauricio leads technical delivery, designing AI use cases from scoping through to production.",
          photo: mfPhoto,
          initials: "MF",
        },
        {
          name: "Joaquin Molina",
          role: "CRO",
          bio: "Thirty years operating BSS/OSS/VAS across the Americas and Europe, with deep specialisation in MVNOs and IoT segments. Joaquin has led Digital Transformation programmes for Communication Service Providers and understands the commercial and technical constraints of mid-tier operators.",
          photo: jmPhoto,
          initials: "JM",
        },
        {
          name: "Sanjay Pandey",
          role: "COO",
          bio: "Three decades leading delivery teams across EMEA, Latin America, and South-East Asia — from complex technology programmes to strategic commercial deals. Sanjay anchors sapium.ai's operations, ensuring every engagement runs to scope, budget, and measurable outcome.",
          photo: spPhoto,
          initials: "SP",
        },
      ]}
    />
    <ContactCTA />
  </main>
</BaseLayout>
