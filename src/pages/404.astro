---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Page Not Found — sapium.ai"
  description="The page you are looking for does not exist. Return to the sapium.ai homepage."
  ogImage="/og-default.png"
  canonicalUrl="https://sapium.ai/404"
>
  <main id="main-content" class="min-h-[60vh] flex items-center">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h1 class="text-4xl font-bold text-textPrimary mb-4">Page not found.</h1>
      <p class="text-textMuted mb-8">
        The page you are looking for does not exist or has been moved.
      </p>
      <a href="/" class="btn-primary focus-ring">Go home</a>
    </div>
  </main>
</BaseLayout>
