---
import TeamCard from './TeamCard.astro'
import type { ImageMetadata } from 'astro'

type TeamMember = {
  name: string
  role: string
  bio: string
  photo?: ImageMetadata
  initials: string
}

type Props = {
  heading: string
  members: TeamMember[]
}

const { heading, members } = Astro.props
---

<section aria-labelledby="team-heading" class="py-12 lg:py-20">
  <div class="max-w-6xl mx-auto px-6">
    <h2 id="team-heading" class="font-display text-3xl font-semibold text-textPrimary mb-12 tracking-tight">
      {heading}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {members.map((member) => (
        <TeamCard
          name={member.name}
          role={member.role}
          bio={member.bio}
          photo={member.photo}
          initials={member.initials}
        />
      ))}
    </div>
  </div>
</section>
