---
type Props = {
  headline: string
  subheadline: string
  primaryCta: { label: string; href: string }
  secondaryCta: { label: string; href: string }
}

const { headline, subheadline, primaryCta, secondaryCta } = Astro.props
---

<section class="hero-section relative min-h-[100dvh] flex items-center bg-bgBase pt-16" aria-labelledby="hero-heading">
  <div class="pl-20 lg:pl-24 pr-8 lg:pr-16 py-24 max-w-4xl">
    <span class="tag-badge mb-6 inline-flex">AI &amp; Data Consulting</span>

    <h1
      id="hero-heading"
      class="font-display text-4xl lg:text-6xl font-bold text-textPrimary mb-6 leading-tight"
      style="letter-spacing: -0.02em;"
    >
      {headline}
    </h1>

    <p class="text-textMuted text-lg lg:text-xl mb-10 max-w-2xl leading-relaxed">
      {subheadline}
    </p>

    <div class="flex flex-col gap-4 sm:flex-row">
      <a href={primaryCta.href} class="btn-primary focus-ring text-center">
        {primaryCta.label}
      </a>
      <a href={secondaryCta.href} class="btn-outline focus-ring text-center">
        {secondaryCta.label}
      </a>
    </div>
  </div>
</section>

<style>
  .hero-section::before {
    content: '';
    position: absolute;
    left: 40px;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(135deg, #7030A0 0%, #0D1B2A 100%);
  }
</style>
