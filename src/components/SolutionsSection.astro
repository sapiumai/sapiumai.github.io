---
import SolutionCard from './SolutionCard.astro'

type Solution = {
  industry: string
  title: string
  description: string
}
type Props = {
  heading: string
  subheading?: string
  solutions: Solution[]
}
const { heading, subheading, solutions } = Astro.props
---
<section aria-labelledby="solutions-heading" class="py-12 lg:py-20">
  <div class="max-w-6xl mx-auto px-6">
    <h2 id="solutions-heading" class={`font-display text-3xl font-semibold text-textPrimary tracking-tight ${subheading ? 'mb-4' : 'mb-10'}`}>
      {heading}
    </h2>
    {subheading && (
      <p class="text-textMuted text-lg mb-10 max-w-2xl">{subheading}</p>
    )}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {solutions.map((solution) => (
        <SolutionCard
          industry={solution.industry}
          title={solution.title}
          description={solution.description}
        />
      ))}
    </div>
  </div>
</section>
